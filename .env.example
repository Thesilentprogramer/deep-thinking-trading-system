# Copy this file to .env and fill in your API keys.
# Never commit your .env file to version control.

# NVIDIA API Key (required)
# Get from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Tavily API Key (required for web search tools)
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Finnhub API Key (required for financial news)
# Get from: https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API Key (required for Indian/global stock data)
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API=your_alpha_vantage_api_key_here

# Financial Datasets API Key (optional – for additional financial data)
# Get from: https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=your_financial_datasets_api_key_here
